"""
ECG-TransNet — Explainability Figure Generator
================================================
Generates Figure 6: Grad-CAM (top row) + SHAP (bottom row)
for three representative arrhythmia classes:
  - Class 0: Normal beat
  - Class 2: Ventricular ectopic beat
  - Class 4: Right bundle branch block

REQUIREMENTS:
    pip install torch numpy matplotlib shap scipy

USAGE:
    1. Replace the MODEL LOADING section with your actual model.
    2. Replace the DATA LOADING section with your actual data.
    3. Run: python generate_xai_figure.py
    4. Output saved as: xai_figure.pdf and xai_figure.png
"""

import numpy as np
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec
import torch
import torch.nn as nn
import shap
from scipy.ndimage import zoom

# ──────────────────────────────────────────────────────────────────────────────
# CONFIGURATION — edit these to match your setup
# ──────────────────────────────────────────────────────────────────────────────
MODEL_PATH       = "ecg_transnet_best.pth"   # path to your saved model weights
SEGMENT_LENGTH   = 250                        # samples per beat segment
NUM_CLASSES      = 23
TARGET_CLASSES   = [0, 2, 4]                  # classes to visualize
CLASS_NAMES      = {
    0: "Normal Beat\n(Class 0)",
    2: "Ventricular Ectopic\n(Class 2)",
    4: "Right Bundle Branch Block\n(Class 4)"
}
SHAP_BACKGROUND  = 100   # number of background samples for SHAP DeepExplainer
OUTPUT_PDF       = "xai_figure.pdf"
OUTPUT_PNG       = "xai_figure.png"
DEVICE           = torch.device("cuda" if torch.cuda.is_available() else "cpu")
RANDOM_SEED      = 42


# ──────────────────────────────────────────────────────────────────────────────
# SECTION 1: MODEL DEFINITION
# Paste your exact ECG-TransNet class here.
# The example below matches the architecture described in the paper.
# ──────────────────────────────────────────────────────────────────────────────

class ConvBlock(nn.Module):
    def __init__(self, in_ch, out_ch, kernel_size, dropout=0.3):
        super().__init__()
        self.block = nn.Sequential(
            nn.Conv1d(in_ch, out_ch, kernel_size, padding=kernel_size // 2),
            nn.BatchNorm1d(out_ch),
            nn.ReLU(),
            nn.MaxPool1d(2),
            nn.Dropout(dropout)
        )
    def forward(self, x):
        return self.block(x)


class ECGTransNet(nn.Module):
    def __init__(self, num_classes=23, d_model=128, nhead=4,
                 num_encoder_layers=2, dim_feedforward=256,
                 dropout=0.3, attn_dropout=0.1):
        super().__init__()
        # CNN backbone
        self.conv1 = ConvBlock(1,  32,  5, dropout)
        self.conv2 = ConvBlock(32, 64,  5, dropout)
        self.conv3 = ConvBlock(64, 128, 3, dropout)

        # Embedding projection
        self.proj = nn.Conv1d(128, d_model, kernel_size=1)

        # Positional encoding (sinusoidal, fixed)
        self.register_buffer(
            "pos_enc",
            self._build_pos_enc(seq_len=31, d_model=d_model)
        )

        # Transformer encoder
        enc_layer = nn.TransformerEncoderLayer(
            d_model=d_model,
            nhead=nhead,
            dim_feedforward=dim_feedforward,
            dropout=attn_dropout,
            batch_first=True
        )
        self.transformer = nn.TransformerEncoder(enc_layer,
                                                  num_layers=num_encoder_layers)

        # Classification head
        self.classifier = nn.Linear(d_model, num_classes)

    @staticmethod
    def _build_pos_enc(seq_len, d_model):
        pe = torch.zeros(seq_len, d_model)
        pos = torch.arange(0, seq_len).unsqueeze(1).float()
        div = torch.exp(
            torch.arange(0, d_model, 2).float() * (-np.log(10000.0) / d_model)
        )
        pe[:, 0::2] = torch.sin(pos * div)
        pe[:, 1::2] = torch.cos(pos * div)
        return pe.unsqueeze(0)   # (1, seq_len, d_model)

    def forward(self, x):
        # x: (B, 1, 250)
        x = self.conv1(x)        # (B, 32,  125)
        x = self.conv2(x)        # (B, 64,   62)
        x = self.conv3(x)        # (B, 128,  31)
        x = self.proj(x)         # (B, 128,  31)
        x = x.permute(0, 2, 1)  # (B, 31, 128)
        x = x + self.pos_enc
        x = self.transformer(x) # (B, 31, 128)
        x = x.mean(dim=1)       # (B, 128)  — global average pool
        return self.classifier(x)


# ──────────────────────────────────────────────────────────────────────────────
# SECTION 2: GRAD-CAM IMPLEMENTATION
# Hooks into the last conv block to extract activations and gradients.
# ──────────────────────────────────────────────────────────────────────────────

class GradCAM1D:
    """
    Grad-CAM for 1D CNN layers.
    target_layer: the nn.Module layer to hook (e.g. model.conv3.block[0])
    """
    def __init__(self, model, target_layer):
        self.model = model
        self.target_layer = target_layer
        self.activations = None
        self.gradients   = None
        self._register_hooks()

    def _register_hooks(self):
        def forward_hook(module, input, output):
            # output shape: (B, C, L)
            self.activations = output.detach()

        def backward_hook(module, grad_in, grad_out):
            # grad_out[0] shape: (B, C, L)
            self.gradients = grad_out[0].detach()

        self.target_layer.register_forward_hook(forward_hook)
        self.target_layer.register_full_backward_hook(backward_hook)

    def generate(self, input_tensor, target_class):
        """
        input_tensor : (1, 1, 250) torch tensor on DEVICE
        target_class : int
        Returns saliency map of shape (250,) normalized to [0, 1]
        """
        self.model.zero_grad()
        output = self.model(input_tensor)          # (1, 23)
        score  = output[0, target_class]
        score.backward()

        # Global average pool gradients over temporal dimension
        weights = self.gradients.mean(dim=2, keepdim=True)   # (1, C, 1)

        # Weighted combination of activation maps
        cam = (weights * self.activations).sum(dim=1)        # (1, L)
        cam = torch.relu(cam).squeeze().cpu().numpy()        # (L,)

        # Upsample from feature map length (~31) to input length (250)
        if cam.shape[0] != 250:
            scale = 250 / cam.shape[0]
            cam   = zoom(cam, scale)

        # Normalize to [0, 1]
        cam_min, cam_max = cam.min(), cam.max()
        if cam_max - cam_min > 1e-8:
            cam = (cam - cam_min) / (cam_max - cam_min)
        else:
            cam = np.zeros_like(cam)

        return cam


# ──────────────────────────────────────────────────────────────────────────────
# SECTION 3: DATA LOADING
